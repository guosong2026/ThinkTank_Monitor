# ThinkTank Monitor 邮件配置示例文件
# 复制此文件为 .env 并填入实际值
# 注意：请将 .env 添加到 .gitignore 避免泄露敏感信息

# ========================================
# SMTP服务器配置
# ========================================

# Outlook邮箱配置（默认）
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587

# 其他邮箱配置示例：
# 163邮箱：
# SMTP_SERVER=smtp.163.com
# SMTP_PORT=465  # SSL端口

# QQ邮箱：
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=587  # TLS端口

# Gmail邮箱（需要应用专用密码）：
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# ========================================
# 发件人配置（必须设置）
# ========================================

# 发件人邮箱地址
SENDER_EMAIL=guosong2023@outlook.com

# SMTP授权码（不是邮箱密码！）
# 如何获取授权码：
# 1. Outlook: 账户设置 → 安全 → 应用密码
# 2. 163/QQ: 邮箱设置 → POP3/SMTP/IMAP → 开启服务 → 获取授权码
SENDER_PASSWORD=doxsnaztyrecxmgl


# ========================================
# 收件人配置（必须设置）
# ========================================

# 收件人邮箱列表，多个邮箱用逗号分隔
RECIPIENT_EMAILS=ghl10201812@163.com

# ========================================
# 可选配置
# ========================================

# 邮件主题前缀（可选）
# EMAIL_SUBJECT_PREFIX=【新报告监控】

# 检查间隔（小时），Web界面中可动态调整
# CHECK_INTERVAL_HOURS=1

# 监控启用状态（1=启用，0=禁用），Web界面中可控制
# MONITOR_ENABLED=1

# ========================================
# 使用说明
# ========================================
# 1. 复制此文件为 .env
#    cp .env.example .env
# 2. 编辑 .env 文件，填入实际配置
# 3. 确保 .env 在 .gitignore 中
# 4. 运行测试：
#    python email_sender.py --test
# 5. 启动Web界面：
#    python app.py 或运行 start_web.bat/start_web.sh