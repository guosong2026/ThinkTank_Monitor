# ThinkTank Monitor 邮件配置示例文件
# 复制此文件为 .env 并填入实际值
# 注意：请将 .env 添加到 .gitignore 避免泄露敏感信息

# ========================================
# 火山方舟AI总结配置（豆包大模型）
# ========================================

# 火山方舟API密钥（从 https://www.volcengine.com/docs/ark 获取）
ARK_API_KEY=your_ark_api_key_here

# API基础URL（默认使用北京区域）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 模型ID（豆包大模型）
ARK_MODEL_ID=doubao-pro-1m-preview-20250515

# AI请求间隔（秒），用于限制CPU瞬时负载，建议2-5秒
AI_SUMMARY_DELAY=2.0

# ========================================
# 邮件发送提供商配置
# ========================================

# 邮件发送提供商（必填）：smtp, sendgrid, mailgun
# 对于PythonAnywhere免费版，建议使用sendgrid
EMAIL_PROVIDER=smtp

# ========================================
# SMTP服务器配置（仅当EMAIL_PROVIDER=smtp时使用）
# ========================================

# Outlook邮箱配置（默认）
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587

# 其他邮箱配置示例：
# 163邮箱（在PythonAnywhere中可能不可用）：
# SMTP_SERVER=smtp.163.com
# SMTP_PORT=465  # SSL端口

# QQ邮箱（在PythonAnywhere中可能不可用）：
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=587  # TLS端口

# Gmail邮箱（PythonAnywhere免费版允许）：
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587

# ========================================
# SendGrid API配置（仅当EMAIL_PROVIDER=sendgrid时使用）
# ========================================

# SendGrid API密钥（从SendGrid控制台获取）
# 免费注册：https://sendgrid.com/free/
# 每月100封免费邮件
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ========================================
# Mailgun API配置（仅当EMAIL_PROVIDER=mailgun时使用）
# ========================================

# Mailgun API密钥（从Mailgun控制台获取）
# 免费注册：https://www.mailgun.com/
# 前3个月每月10,000封免费邮件，之后每月625封
MAILGUN_API_KEY=your_mailgun_api_key_here

# Mailgun域名（从Mailgun控制台获取）
MAILGUN_DOMAIN=your_mailgun_domain_here

# ========================================
# 发件人配置（所有模式通用）
# ========================================

# 发件人邮箱地址
SENDER_EMAIL=guosong2023@outlook.com

# SMTP授权码（仅当EMAIL_PROVIDER=smtp时使用）
# 如何获取授权码：
# 1. Outlook: 账户设置 → 安全 → 应用密码
# 2. 163/QQ: 邮箱设置 → POP3/SMTP/IMAP → 开启服务 → 获取授权码
SENDER_PASSWORD=your_smtp_password_here

# ========================================
# 收件人配置（所有模式通用）
# ========================================

# 收件人邮箱列表，多个邮箱用逗号分隔
RECIPIENT_EMAILS=ghl10201812@163.com

# ========================================
# 可选配置
# ========================================

# 邮件主题前缀（可选）
# EMAIL_SUBJECT_PREFIX=【新报告监控】

# 检查间隔（小时），Web界面中可动态调整
# CHECK_INTERVAL_HOURS=1

# 监控启用状态（1=启用，0=禁用），Web界面中可控制
# MONITOR_ENABLED=1

# ========================================
# 使用说明
# ========================================
# 1. 复制此文件为 .env
#    cp .env.example .env
# 2. 编辑 .env 文件，填入实际配置
# 3. 确保 .env 在 .gitignore 中
# 4. 运行测试：
#    python email_sender.py --test
# 5. 启动Web界面：
#    python app.py 或运行 start_web.bat/start_web.sh

# ========================================
# PythonAnywhere免费版推荐配置
# ========================================
# 对于PythonAnywhere免费版（SMTP受限），推荐使用：
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=你的SendGrid API密钥
# SENDER_EMAIL=已验证的发件人邮箱
# RECIPIENT_EMAILS=接收通知的邮箱

# ========================================
# 邮件API服务注册指南
# ========================================
# 1. SendGrid (推荐)：
#    - 注册：https://sendgrid.com/free/
#    - 创建API密钥：Settings → API Keys → Create API Key
#    - 验证发件人邮箱：Settings → Sender Authentication
#    - 每月100封免费邮件，足够监控使用
#
# 2. Mailgun (备选)：
#    - 注册：https://www.mailgun.com/
#    - 创建API密钥：API Security → API Keys
#    - 获取域名：Sending → Domains
#    - 前3个月10,000封免费，之后625封/月
#
# 3. SMTP模式 (仅在非PythonAnywhere环境或付费版中使用)
#    - 使用Outlook/Gmail等邮箱的SMTP服务
#    - 注意：PythonAnywhere免费版可能阻止SMTP连接